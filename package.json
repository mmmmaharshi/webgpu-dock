{
  "name": "webgpu-dock",
  "version": "1.0.0",
  "private": true,
  "module": "server.ts",
  "description": "WebGPU molecular docking",
  "scripts": {
    "build:app": "bun build src/app.ts --outfile=public/app.js --target=browser --format=esm",
    "start": "bun run build:app && bun run server.ts",
    "typecheck": "tsgo --noEmit",
    "dev": "bun run build:app && bun --hot server.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "^7.0.0-dev.20260705.1",
    "@webgpu/types": "^0.1.71",
    "typescript": "^6.0.3"
  }
}
