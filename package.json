{
  "name": "webgpu-dock",
  "version": "1.0.0",
  "private": true,
  "module": "server.ts",
  "description": "WebGPU molecular docking",
  "scripts": {
    "build:app": "bun build public/app.ts --outfile=public/app.js --target=browser --format=esm",
    "start": "bun run build:app && bun run server.ts",
    "dev": "bun run build:app && bun --hot server.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@webgpu/types": "^0.1.71"
  }
}
